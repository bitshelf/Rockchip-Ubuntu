# STRUCTURE for Rockchip Ubuntu Desktop (GNOME) image

feature follow-recommends
feature no-follow-build-depends
required:
minimal: required
boot:
standard: minimal
installer:
build-essential: required
raspi-common: standard

# Server basics (keep ssh, network)
server: standard
server-cloud-minimal:
server-minimal: server-cloud-minimal
server-ship-live: server-minimal

# Desktop chain (GNOME via ubuntu-desktop-minimal)
desktop-common: standard
desktop-minimal: desktop-common
desktop: desktop-minimal desktop-common
development: desktop

cloud-minimal: server-cloud-minimal

# Supported sets (minimal, only what's available locally)
supported-cloud: standard
supported-development-common: standard
supported-kernel-common: standard
supported-maas: standard
supported-hardware-common: standard
supported-installer-common: standard
supported-network-common: standard
supported-raspi-common: standard
supported-sysadmin-common: standard
supported-server: supported-hardware-common supported-installer-common supported-network-common supported-sysadmin-common supported-raspi-common build-essential supported-development-common supported-kernel-common supported-cloud supported-maas

supported: server-ship-live cloud-minimal
# make sure supported remains the last entry

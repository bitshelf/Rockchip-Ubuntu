# ==========================================================================
# Ubuntu Image Build Configuration (Example)
#
#   cp .env.example .env
#   vim .env
#
# All values use ${VAR:-default} — environment variables take priority.
# Temporary override: UBUNTU_VARIANT=server BUILD_MODE=local bash ubuntu/build.sh
# ==========================================================================

SOC_MODEL="${SOC_MODEL:-rk3576}"
UBUNTU_SERIES="${UBUNTU_SERIES:-noble}"
UBUNTU_VARIANT="${UBUNTU_VARIANT:-desktop}"
BUILD_MODE="${BUILD_MODE:-local}"
PACKAGE_METHOD="${PACKAGE_METHOD:-mkupdate}"

# --- Remote Build (only when BUILD_MODE=remote) ---
BUILD_HOST="${BUILD_HOST:-192.168.1.XXX}"
BUILD_USER="${BUILD_USER:-root}"
BUILD_PASS="${BUILD_PASS:-}"
BUILD_DIR="${BUILD_DIR:-/tmp/ubuntu-build}"

# Remote target default user (created in built image)
REMOTE_DEFAULT_USER="${REMOTE_DEFAULT_USER:-ubuntu}"
REMOTE_DEFAULT_PASS="${REMOTE_DEFAULT_PASS:-ubuntu}"
